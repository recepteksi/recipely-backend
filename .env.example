NODE_ENV=production
PORT=3000

# Postgres (docker network hostname = service name)
POSTGRES_USER=recipely
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=recipely
DATABASE_URL=postgresql://recipely:change_me_in_prod@postgres:5432/recipely?schema=public&connection_limit=5

# Auth
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# AES-256-GCM key for /api/v1 request/response envelope. Generate with:
#   openssl rand -hex 32
# The mobile client must ship the SAME 64-hex value (EXPO_PUBLIC_API_AES_KEY).
# Caveat: anyone with the mobile binary can extract the key — TLS is the
# proper transport-layer fix; this envelope is a soft wrapper.
API_AES_KEY=replace-with-openssl-rand-hex-32

# Admin panel (AdminJS at /admin)
# When set, the seed creates an admin user on first boot. Leave blank to skip.
# Password must be at least 12 chars. After bootstrap, manage admins via /admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# AdminJS session cookie Secure flag. Keep false while serving plain HTTP —
# browsers reject Secure cookies over HTTP, which silently breaks login.
# Flip to true once HTTPS terminates in front of the API.
COOKIE_SECURE=false

# AI recipe generation. Swap provider/model at runtime — the use case is
# provider-agnostic and the bootstrap reads these env vars to pick the adapter.
# Supported providers:
#   'groq'      — generous free tier, no card required (default)
#   'gemini'    — free tier via AI Studio, but unavailable in some regions
#   'anthropic' — paid, no free tier
AI_PROVIDER=groq
# Provider-specific model id.
#   groq:      'llama-3.3-70b-versatile' (default), 'llama-3.1-8b-instant'
#   gemini:    'gemini-2.0-flash', 'gemini-2.5-flash', 'gemini-2.5-pro'
#   anthropic: 'claude-haiku-4-5', 'claude-sonnet-4-6', 'claude-opus-4-7'
AI_MODEL=llama-3.3-70b-versatile
# Only needed if AI_PROVIDER=groq. Get from https://console.groq.com/keys.
GROQ_API_KEY=
# Only needed if AI_PROVIDER=gemini. Get from https://aistudio.google.com/apikey.
GEMINI_API_KEY=
# Only needed if AI_PROVIDER=anthropic. Get from https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Firebase project ID for social sign-in (Google / Apple via Firebase Auth).
# Find it in: Firebase console → Project settings → General → Project ID.
FIREBASE_PROJECT_ID=

# Firebase Admin SDK service account JSON (base64-encoded) — required for push notifications.
# Generate from: Firebase console → Project settings → Service accounts → Generate new private key
# Encode with: base64 -i serviceAccount.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# SMTP for transactional emails (registration verification codes + password reset).
# All optional — if any are unset the server falls back to a no-op sender: emails
# are not actually delivered, and in non-production the 6-digit code is returned in
# the API response as `devCode` (and logged) so you can still complete the flow.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# From address shown on outgoing mail, e.g. "Recipely <no-reply@recipely.app>".
SMTP_FROM=
# Universal-link base used to build password-reset deep links
# (<APP_BASE_URL>/reset-password?token=...) that the mobile app intercepts.
# Must match the associated-domain registered in the iOS/Android app.
APP_BASE_URL=https://recipely.net
