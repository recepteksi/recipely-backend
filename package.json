{
  "name": "recipely-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Recipely backend — Clean Architecture + DDD on Node.js/Express/Prisma/Postgres.",
  "main": "dist/presentation/server/index.js",
  "engines": {
    "node": ">=20.11 <21"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/presentation/server/index.js",
    "dev": "tsx watch src/presentation/server/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "import:foodcom": "tsx scripts/import-foodcom.ts",
    "migrate:images": "tsx --env-file=.env scripts/migrate-images.ts"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@adminjs/express": "^6.1.1",
    "@adminjs/prisma": "^5.0.4",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.3",
    "@types/express-session": "^1.19.0",
    "adminjs": "^7.8.17",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "express-session": "^1.19.0",
    "groq-sdk": "^1.2.0",
    "helmet": "^8.0.0",
    "i18next": "^26.0.8",
    "i18next-fs-backend": "^2.6.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/i18next": "^12.1.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.6",
    "@types/sharp": "^0.31.1",
    "csv-parse": "^5.5.6",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "ts-jest": "^29.2.5",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
