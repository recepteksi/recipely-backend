// Recipely — Prisma schema
// Keep this aligned with domain entities. Infra maps DB rows -> domain via mappers.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"] // Alpine runtime
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Users ----------

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.Citext
  passwordHash String?  @map("password_hash")
  displayName  String   @map("display_name")
  bio          String?  @map("bio")
  photoUrl     String?  @map("photo_url")
  role         String   @default("user") @map("role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  recipes   Recipe[]   @relation("RecipeOwner")
  favorites Favorite[]
  likes     RecipeLike[]
  commentLikes CommentLike[]
  aiGenerationLogs AIGenerationLog[]
  comments  Comment[]  @relation("CommentAuthor")
  fcmTokens            FcmToken[]
  sentNotifications    Notification[] @relation("NotificationSender")
  receivedNotifications Notification[] @relation("NotificationRecipient")
  following    UserFollow[] @relation("UserFollower")
  followers    UserFollow[] @relation("UserFollowing")
  passwordResetTokens PasswordResetToken[]
  drafts       RecipeDraft[]

  @@map("users")
}

// ---------- Recipes ----------

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum RecipeCategory {
  BREAKFAST
  BRUNCH
  LUNCH
  DINNER
  DESSERT
  SNACK
  DRINK
  SMOOTHIE
  SOUP
  STEW
  SALAD
  APPETIZER
  SIDE_DISH
  MAIN_COURSE
  PASTA
  PIZZA
  SANDWICH
  BREAD
  BAKING
  SAUCE
}

enum CuisineKey {
  TURKISH
  ITALIAN
  MEXICAN
  CHINESE
  JAPANESE
  INDIAN
  FRENCH
  GREEK
  AMERICAN
  MEDITERRANEAN
  THAI
  SPANISH
  KOREAN
  MIDDLE_EASTERN
  GERMAN
  BRITISH
  VIETNAMESE
  LEBANESE
  MOROCCAN
  BRAZILIAN
  RUSSIAN
  PERSIAN
  CARIBBEAN
  FILIPINO
  INDONESIAN
  PAKISTANI
  CAUCASIAN
  AFRICAN
  OTHER
}

model Recipe {
  id              String         @id @default(uuid()) @db.Uuid
  name            Json           @map("name") @db.Json
  cuisine         CuisineKey     @default(OTHER) @map("cuisine")
  category        RecipeCategory @default(MAIN_COURSE) @map("category")
  difficulty      Difficulty     @default(EASY)
  ingredients     Json           @map("ingredients") @db.Json
  instructions    Json           @map("instructions") @db.Json
  prepTimeMinutes Int            @map("prep_time_minutes")
  cookTimeMinutes Int            @map("cook_time_minutes")
  servings        Int            @default(1)
  caloriesPerServing Int         @default(0) @map("calories_per_serving")
  nutrition          Json?       @map("nutrition") @db.Json
  tips               Json?       @map("tips") @db.Json
  // Materialized prep+cook total. Maintained by the application layer on
  // create/update so the `?maxTime=` filter can use an index.
  totalTimeMinutes Int           @default(0) @map("total_time_minutes")
  image           String
  rating          Float          @default(0)
  tags            Json           @map("tags") @db.Json
  mealType        Json           @default("[]") @map("meal_type") @db.Json
  commentCount    Int            @default(0) @map("comment_count")
  viewCount       Int            @default(0) @map("view_count")
  isPublished        Boolean     @default(true) @map("is_published")
  moderationStatus   String      @default("approved") @map("moderation_status")
  // Canonical URL of the upstream recipe when imported from a third-party
  // dataset (food.com, etc.). NULL for manually-created recipes. Unique so
  // re-running the import script upserts instead of duplicating.
  sourceUrl       String?        @unique @map("source_url")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  ownerId String @map("owner_id") @db.Uuid
  owner   User   @relation("RecipeOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  favorites Favorite[]
  likes     RecipeLike[]
  media     RecipeMedia[]
  aiGenerationLogs AIGenerationLog[]
  comments  Comment[]
  notifications Notification[]

  // Query shape: list + search + pagination on createdAt
  @@index([isPublished, createdAt(sort: Desc)])
  @@index([totalTimeMinutes])
  @@index([isPublished, rating(sort: Desc)])
  @@index([ownerId, moderationStatus])
  @@index([category])
  @@index([cuisine])
  @@index([commentCount(sort: Desc)])
  @@map("recipes")
}

// Photos and videos attached to a recipe. Frontend renders the gallery on the
// detail screen. `type` is "image" or "video" — kept as a plain string instead
// of an enum so we can add types (e.g. audio) without a schema change.
model RecipeMedia {
  id        String   @id @default(uuid()) @db.Uuid
  recipeId  String   @map("recipe_id") @db.Uuid
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  type      String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([recipeId, position])
  @@map("recipe_media")
}

// ---------- Favorites ----------

model Favorite {
  // Surrogate single-column PK so the table is a first-class AdminJS resource
  // (AdminJS/@adminjs/prisma requires a single `id`). The (userId, recipeId)
  // pair stays unique, so the named composite selector is unchanged for queries.
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  recipeId  String   @map("recipe_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("favorites")
}

// ---------- Likes ----------

model RecipeLike {
  // Surrogate single-column PK for AdminJS; see Favorite for rationale.
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  recipeId  String   @map("recipe_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([recipeId])
  @@map("recipe_likes")
}

// ---------- AI Generation Logs ----------

// Audit trail for AI-generated recipes. `generatedRecipeId` is nullable so we
// can record failed attempts (parse errors, upstream API failures) too.
model AIGenerationLog {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  userPrompt        String   @map("user_prompt")
  generatedRecipeId String?  @map("generated_recipe_id") @db.Uuid
  provider          String
  modelUsed         String   @map("model_used")
  status            String
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [generatedRecipeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_generation_logs")
}

// ---------- Feature Flags ----------

model FeatureFlag {
  key     String  @id
  enabled Boolean @default(true)

  @@map("feature_flags")
}

// ---------- Comments ----------

model Comment {
  id               String    @id @default(uuid()) @db.Uuid
  body             String
  rating           Int?      @map("rating")
  moderationStatus String    @default("approved") @map("moderation_status")
  recipeId         String    @map("recipe_id") @db.Uuid
  authorId         String    @map("author_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  author User   @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  likes  CommentLike[]

  @@index([recipeId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("comments")
}

model CommentLike {
  // Surrogate single-column PK for AdminJS; see Favorite for rationale.
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

// ---------- User Follows ----------

model UserFollow {
  // Surrogate single-column PK for AdminJS; see Favorite for rationale.
  id           String   @id @default(uuid()) @db.Uuid
  followerId   String   @map("follower_id") @db.Uuid
  followingId  String   @map("following_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  follower  User @relation("UserFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

// ---------- Password Reset Tokens ----------

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------- Pending Registrations ----------

// Holds an in-flight signup until the emailed 6-digit code is verified. The
// real User is created only on verify, then the row is deleted. Keyed by email
// (unique) so a re-request replaces any prior pending row for that address.
model PendingRegistration {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.Citext
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  codeHash     String   @map("code_hash")
  expiresAt    DateTime @map("expires_at")
  attempts     Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  lastCodeSentAt DateTime @default(now()) @map("last_code_sent_at")

  @@index([expiresAt])
  @@map("pending_registrations")
}

// ---------- FCM Tokens ----------

model FcmToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String   // "ios" | "android" | "web"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("fcm_tokens")
}

// ---------- Recipe Drafts ----------

// Work-in-progress recipe drafts. One draft per in-progress session; the client
// upserts by id. Snapshot and chatHistory are intentionally flexible JSON —
// drafts are incomplete by design (hence no validation for completeness at the
// domain level). Cascade-deleted when the owning user is deleted.
model RecipeDraft {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @map("owner_id") @db.Uuid
  prompt      String
  snapshot    Json     @map("snapshot") @db.Json
  chatHistory Json     @map("chat_history") @db.Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, updatedAt(sort: Desc)])
  @@map("recipe_drafts")
}

// ---------- Notifications ----------

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  recipientId String   @map("recipient_id") @db.Uuid
  type        String   // "comment" | "like" | "follow" | "ai_completed" | "moderation"
  senderId    String?  @map("sender_id") @db.Uuid
  recipeId    String?  @map("recipe_id") @db.Uuid
  read        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  recipient   User     @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender      User?    @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  recipe      Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([recipientId, read, createdAt(sort: Desc)])
  @@map("notifications")
}
